{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UCSD Skills Library catalog (ideas.json)",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "name",
      "title",
      "description",
      "category",
      "status",
      "publicationStatus",
      "tier",
      "owner",
      "updated",
      "checklist",
      "links"
    ],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
      "name": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
      "title": { "type": "string", "minLength": 1 },
      "description": { "type": "string", "minLength": 1 },
      "category": { "type": "string", "minLength": 1 },
      "status": { "enum": ["planned", "idea", "in-progress", "review", "done", "built"] },
      "publicationStatus": { "enum": ["draft", "ready", "published", "archived"] },
      "tier": {
        "enum": ["core", "verified", "experimental"],
        "description": "Trust tier. core = team-maintained and fully vetted; verified = community-contributed and reviewed; experimental = clearly use-at-your-own-risk."
      },
      "owner": { "type": "string", "minLength": 1 },
      "updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
      "checklist": {
        "type": "object",
        "required": ["definition", "skillDraft", "references", "reviewed", "published"],
        "additionalProperties": false,
        "properties": {
          "definition": { "type": "boolean" },
          "skillDraft": { "type": "boolean" },
          "references": { "type": "boolean" },
          "reviewed": { "type": "boolean" },
          "published": { "type": "boolean" }
        }
      },
      "links": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["label", "url"],
          "additionalProperties": false,
          "properties": {
            "label": { "type": "string", "minLength": 1 },
            "url": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
